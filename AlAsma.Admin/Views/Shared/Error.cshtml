@{
    ViewData["Title"] = ViewBag.Title ?? "خطأ في النظام";
    Layout = null;
    var statusCode = (int)(ViewBag.StatusCode ?? 500);
    var title = (string)(ViewBag.Title ?? "خطأ في النظام");
    var message = (string)(ViewBag.Message ?? "نأسف، حدث خطأ غير متوقع في النظام.");
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@title — الأسمى</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body {
            display: flex; align-items: center; justify-content: center;
            min-height: 100vh; background: #0a0a0a; margin: 0;
            font-family: 'Segoe UI', Tahoma, Arial, sans-serif;
            direction: rtl; color: #fff;
        }
        .error-box {
            text-align: center; padding: 3rem 2.5rem;
            background: #1a1a1a; border-radius: 16px;
            border: 1px solid #333; max-width: 480px; width: 90%;
        }
        .error-icon {
            width: 72px; height: 72px; margin: 0 auto 1.5rem;
        }
        .error-icon svg { width: 100%; height: 100%; }
        .status-code {
            font-size: 4rem; font-weight: 800; color: #e74c3c;
            line-height: 1; margin-bottom: 0.5rem;
        }
        .error-box h1 {
            color: #fff; font-size: 1.6rem; margin-bottom: 0.75rem;
            font-weight: 700;
        }
        .error-box p {
            color: #999; margin-bottom: 2rem; font-size: 0.95rem;
            line-height: 1.6;
        }
        .actions {
            display: flex; gap: 0.75rem; justify-content: center;
            flex-wrap: wrap;
        }
        .btn {
            display: inline-flex; align-items: center; gap: 0.5rem;
            padding: 0.75rem 1.75rem; border-radius: 8px;
            text-decoration: none; font-size: 0.9rem; font-weight: 600;
            transition: all 0.2s ease;
        }
        .btn-primary {
            background: #004643; color: white;
        }
        .btn-primary:hover { background: #006560; }
        .btn-secondary {
            background: #2a2a2a; color: #ccc; border: 1px solid #444;
        }
        .btn-secondary:hover { background: #333; color: #fff; }
    </style>
</head>
<body>
    <div class="error-box">
        @* Inline SVG warning icon — no external CDN dependency *@
        <div class="error-icon">
            <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M12 9v4m0 4h.01M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z"
                      stroke="#e74c3c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </div>

        @if (statusCode != 500)
        {
            <div class="status-code">@statusCode</div>
        }

        <h1>@title</h1>
        <p>@message</p>

        <div class="actions">
            <a href="/Account/Login" class="btn btn-primary">
                العودة لتسجيل الدخول
            </a>
            <a href="javascript:history.back()" class="btn btn-secondary">
                ← الرجوع للخلف
            </a>
        </div>
    </div>
</body>
</html>
