@{
    ViewData["Title"] = "خطأ في النظام";
    Layout = null;
}
<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/shared.css">
    <title>خطأ — الأسمى</title>
    <style>
        body { display: flex; align-items: center; justify-content: center; min-height: 100vh; background: var(--bg, #0a0a0a); margin: 0; font-family: 'Segoe UI', sans-serif; }
        .error-box { text-align: center; padding: 3rem; background: #1a1a1a; border-radius: 16px; border: 1px solid #333; max-width: 480px; }
        .error-box i { font-size: 4rem; color: #e74c3c; margin-bottom: 1rem; display: block; }
        .error-box h1 { color: #fff; font-size: 1.8rem; margin-bottom: .5rem; }
        .error-box p { color: #aaa; margin-bottom: 2rem; }
        .back-btn { display: inline-block; padding: .75rem 2rem; background: #004643; color: white; border-radius: 8px; text-decoration: none; font-size: 1rem; }
        .back-btn:hover { background: #006560; }
    </style>
</head>
<body>
    <div class="error-box">
        <i class="fa-solid fa-triangle-exclamation"></i>
        <h1>حدث خطأ غير متوقع</h1>
        <p>نأسف، حدث خطأ في النظام. يرجى المحاولة مرة أخرى.</p>
        <a href="javascript:history.back()" class="back-btn">
            <i class="fa-solid fa-arrow-right"></i> العودة للخلف
        </a>
    </div>
</body>
</html>
