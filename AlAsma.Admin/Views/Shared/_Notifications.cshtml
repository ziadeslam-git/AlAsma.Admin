@if (TempData["Success"] != null)
{
    <div class="mx-4 mt-4 p-4 bg-green-50 dark:bg-green-900/20 border border-green-200 dark:border-green-800 rounded-xl text-green-700 dark:text-green-400 text-sm flex items-center gap-2">
        <span class="material-icons-round text-sm">check_circle</span>
        <span>@TempData["Success"]</span>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="mx-4 mt-4 p-4 bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-xl text-red-700 dark:text-red-400 text-sm flex items-center gap-2">
        <span class="material-icons-round text-sm">error</span>
        <span>@TempData["Error"]</span>
    </div>
}
@if (TempData["Warning"] != null)
{
    <div class="mx-4 mt-4 p-4 bg-yellow-50 dark:bg-yellow-900/20 border border-yellow-200 dark:border-yellow-800 rounded-xl text-yellow-700 dark:text-yellow-400 text-sm flex items-center gap-2">
        <span class="material-icons-round text-sm">warning</span>
        <span>@TempData["Warning"]</span>
    </div>
}
