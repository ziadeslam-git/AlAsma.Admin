@model AuthorEditDto
@{
    ViewData["Title"] = "تعديل بيانات المدير";
}

<main class="flex-grow container mx-auto px-4 sm:px-6 py-8">
    <div class="max-w-2xl mx-auto px-0 sm:px-4">
        <div class="bg-white dark:bg-slate-800 rounded-xl shadow-sm sm:shadow-md p-4 sm:p-8 border-0 sm:border border-slate-200 dark:border-slate-700">
            <div class="flex items-center mb-6 border-b border-slate-100 dark:border-slate-700 pb-4">
                <span class="material-icons-round text-primary ml-2">edit</span>
                <h2 class="text-xl font-bold text-slate-800 dark:text-white">تعديل بيانات المدير</h2>
            </div>
            <form asp-action="Edit" method="post" class="space-y-5">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded text-sm"></div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div>
                        <label asp-for="Name" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">الاسم</label>
                        <input asp-for="Name" class="w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-white focus:border-primary focus:ring-primary text-base py-3" />
                        <span asp-validation-for="Name" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">الكود <span class="text-xs">(لا يمكن تعديله)</span></label>
                        <input type="text" value="@ViewBag.Code" readonly disabled class="w-full rounded-lg border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-700/50 text-slate-400 text-base py-3 cursor-not-allowed" />
                    </div>
                    <div class="md:col-span-2">
                        <label asp-for="Password" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">
                            كلمة المرور الجديدة <span class="text-slate-400 font-normal text-xs">(اتركها فارغة للإبقاء على الحالية)</span>
                        </label>
                        <div class="password-wrapper relative">
                            <input asp-for="Password"
                                   id="pwd_adminEdit"
                                   type="password"
                                   autocomplete="new-password"
                                   class="w-full rounded-lg border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-white focus:border-primary focus:ring-primary text-base py-3 pl-11" />
                            <button type="button"
                                    class="eye-toggle absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 hover:text-slate-600 focus:outline-none">
                                <span class="eye-icon material-icons-round text-xl">visibility</span>
                            </button>
                        </div>
                        <span asp-validation-for="Password" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                 
                   
                </div>

                <div class="flex flex-col-reverse sm:flex-row justify-end gap-3 pt-4 border-t border-slate-100 dark:border-slate-700 mt-6">
                    <a asp-action="Index" class="w-full sm:w-auto text-center px-6 py-3 rounded-lg border border-slate-300 dark:border-slate-600 text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700 text-base font-medium transition-colors">إلغاء</a>
                    <button type="submit" class="w-full sm:w-auto bg-primary hover:bg-primary/90 text-white py-3 px-6 rounded-lg font-medium text-base flex items-center justify-center gap-2 transition-colors">
                        <span class="material-icons-round text-base">save</span>
                        حفظ التعديلات
                    </button>
                </div>
            </form>
        </div>
    </div>
</main>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
