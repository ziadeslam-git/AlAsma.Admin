@model AuthorEditDto
@{
    ViewData["Title"] = "تعديل بيانات المدير";
}

<main class="flex-grow container mx-auto px-4 sm:px-6 py-8">
    <div class="max-w-2xl mx-auto">
        <div class="bg-white dark:bg-slate-800 rounded shadow-md p-8 border border-slate-200 dark:border-slate-700">
            <div class="flex items-center mb-6 border-b border-slate-100 dark:border-slate-700 pb-4">
                <span class="material-icons-round text-primary ml-2">edit</span>
                <h2 class="text-xl font-bold text-slate-800 dark:text-white">تعديل بيانات المدير</h2>
            </div>
            <form asp-action="Edit" method="post" class="space-y-5">
                <input type="hidden" asp-for="Id" />
                <div asp-validation-summary="ModelOnly" class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded text-sm"></div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div>
                        <label asp-for="Name" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">الاسم</label>
                        <input asp-for="Name" class="w-full rounded border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-white focus:border-primary focus:ring-primary text-sm" />
                        <span asp-validation-for="Name" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-slate-500 dark:text-slate-400 mb-1">الكود <span class="text-xs">(لا يمكن تعديله)</span></label>
                        <input type="text" value="@ViewBag.Code" readonly disabled class="w-full rounded border-slate-200 dark:border-slate-700 bg-slate-50 dark:bg-slate-700/50 text-slate-400 text-sm cursor-not-allowed" />
                    </div>
                    <div class="md:col-span-2">
                        <label asp-for="Password" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">
                            كلمة المرور الجديدة <span class="text-slate-400 font-normal text-xs">(اتركها فارغة للإبقاء على الحالية)</span>
                        </label>
                        <input asp-for="Password" type="password" class="w-full rounded border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-white focus:border-primary focus:ring-primary text-sm" />
                        <span asp-validation-for="Password" class="text-red-500 text-xs mt-1 block"></span>
                    </div>
                 
                   
                </div>

                <div class="flex justify-end gap-3 pt-4 border-t border-slate-100 dark:border-slate-700 mt-6">
                    <a asp-action="Index" class="px-5 py-2 rounded border border-slate-300 dark:border-slate-600 text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700 text-sm font-medium transition-colors">إلغاء</a>
                    <button type="submit" class="bg-primary hover:bg-primary/90 text-white px-6 py-2 rounded font-medium text-sm flex items-center gap-2 transition-colors">
                        <span class="material-icons-round text-sm">save</span>
                        حفظ التعديلات
                    </button>
                </div>
            </form>
        </div>
    </div>
</main>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
