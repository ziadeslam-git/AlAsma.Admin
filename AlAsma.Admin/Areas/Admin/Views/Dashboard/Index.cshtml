@model AlAsma.Admin.DTOs.Dashboard.AdminDashboardDto
@{
    ViewData["Title"] = "لوحة المبيعات";
    var today = DateTime.Now.ToString("yyyy/MM/dd");
}

<main class="flex-grow container mx-auto px-4 sm:px-6 py-8">
    <!-- Page Header -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8">
        <div>
            <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">لوحة المبيعات</h2>
            <p class="text-slate-500 dark:text-slate-400">مرحباً بك، إليك نظرة سريعة على الأداء</p>
        </div>
        <div class="mt-4 md:mt-0 flex items-center space-x-2 space-x-reverse bg-surface-light dark:bg-surface-dark px-4 py-2 rounded shadow-sm border border-slate-200 dark:border-slate-700">
            <span class="material-icons-round text-slate-400">calendar_today</span>
            <span class="text-sm font-medium">@today</span>
        </div>
    </div>

    <!-- Stats Row 1 -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
        <!-- Total Operations -->
        <div class="stat-card bg-surface-light dark:bg-surface-dark rounded shadow-sm p-6 border border-slate-100 dark:border-slate-800 opacity-0 animate-fade-in-up">
            <div class="flex justify-between items-start mb-4">
                <div class="bg-blue-50 dark:bg-blue-900/30 p-3 rounded-full text-blue-500 dark:text-blue-400 animate-pulse-vertical">
                    <span class="material-icons-round">receipt_long</span>
                </div>
                <span class="flex items-center text-xs font-semibold text-green-600 bg-green-50 dark:bg-green-900/30 dark:text-green-400 px-2 py-1 rounded">
                    <span class="material-icons-round text-sm ml-1">trending_up</span> مبيعات
                </span>
            </div>
            <div>
                <h3 class="text-slate-500 dark:text-slate-400 text-sm font-medium mb-1">إجمالي العمليات</h3>
                <p class="text-3xl font-bold text-slate-900 dark:text-white">@Model.TotalSales</p>
            </div>
        </div>

        <!-- Total Revenue -->
        <div class="stat-card bg-surface-light dark:bg-surface-dark rounded shadow-sm p-6 border border-slate-100 dark:border-slate-800 opacity-0 animate-fade-in-up">
            <div class="flex justify-between items-start mb-4">
                <div class="bg-green-50 dark:bg-green-900/30 p-3 rounded-full text-green-500 dark:text-green-400 animate-pulse-vertical">
                    <span class="material-icons-round">payments</span>
                </div>
                <span class="flex items-center text-xs font-semibold text-green-600 bg-green-50 dark:bg-green-900/30 dark:text-green-400 px-2 py-1 rounded">
                    إيرادات
                </span>
            </div>
            <div>
                <h3 class="text-slate-500 dark:text-slate-400 text-sm font-medium mb-1">إجمالي المبالغ</h3>
                <p class="text-3xl font-bold text-slate-900 dark:text-white flex items-baseline">
                    @Model.TotalRevenue.ToString("N2") <span class="text-sm font-normal text-slate-500 dark:text-slate-400 mr-1">ج.م</span>
                </p>
            </div>
        </div>

        <!-- Total Authors -->
        <div class="stat-card bg-surface-light dark:bg-surface-dark rounded shadow-sm p-6 border border-slate-100 dark:border-slate-800 opacity-0 animate-fade-in-up">
            <div class="flex justify-between items-start mb-4">
                <div class="bg-purple-50 dark:bg-purple-900/30 p-3 rounded-full text-purple-500 dark:text-purple-400 animate-pulse-vertical">
                    <span class="material-icons-round">groups</span>
                </div>
                <span class="flex items-center text-xs font-semibold text-slate-500 bg-slate-50 dark:bg-slate-800 dark:text-slate-400 px-2 py-1 rounded">
                    مؤلفون
                </span>
            </div>
            <div>
                <h3 class="text-slate-500 dark:text-slate-400 text-sm font-medium mb-1">إجمالي المؤلفين</h3>
                <p class="text-3xl font-bold text-slate-900 dark:text-white">@Model.TotalAuthors</p>
            </div>
        </div>
    </div>

    <!-- Stats Row 2: Contracts -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        <div class="bg-surface-light dark:bg-surface-dark rounded shadow-sm p-5 border-r-4 border-green-500 flex items-center gap-4">
            <div class="bg-green-50 dark:bg-green-900/30 p-3 rounded-full text-green-600"><span class="material-icons-round">check_circle</span></div>
            <div>
                <p class="text-sm text-slate-500 dark:text-slate-400">عقود نشطة</p>
                <p class="text-2xl font-bold text-green-600">@Model.ActiveContracts</p>
            </div>
        </div>
        <div class="bg-surface-light dark:bg-surface-dark rounded shadow-sm p-5 border-r-4 border-yellow-500 flex items-center gap-4">
            <div class="bg-yellow-50 dark:bg-yellow-900/30 p-3 rounded-full text-yellow-600"><span class="material-icons-round">schedule</span></div>
            <div>
                <p class="text-sm text-slate-500 dark:text-slate-400">تنتهي قريباً</p>
                <p class="text-2xl font-bold text-yellow-600">@Model.EndingSoonContracts</p>
            </div>
        </div>
        <div class="bg-surface-light dark:bg-surface-dark rounded shadow-sm p-5 border-r-4 border-red-500 flex items-center gap-4">
            <div class="bg-red-50 dark:bg-red-900/30 p-3 rounded-full text-red-600"><span class="material-icons-round">cancel</span></div>
            <div>
                <p class="text-sm text-slate-500 dark:text-slate-400">منتهية</p>
                <p class="text-2xl font-bold text-red-600">@Model.ExpiredContracts</p>
            </div>
        </div>
    </div>

    <!-- Two-Column Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">

        <!-- Recent Sales Table -->
        <div class="bg-surface-light dark:bg-surface-dark rounded shadow-md border border-slate-200 dark:border-slate-700 overflow-hidden">
            <div class="p-6 border-b border-slate-200 dark:border-slate-700 flex justify-between items-center">
                <div class="flex items-center space-x-2 space-x-reverse">
                    <span class="material-icons-round text-slate-500">history</span>
                    <h3 class="text-lg font-bold text-slate-800 dark:text-white">آخر 5 مبيعات</h3>
                </div>
                <a asp-area="Admin" asp-controller="Sale" asp-action="Index"
                   class="text-sm text-primary dark:text-secondary font-semibold hover:underline">عرض الكل</a>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-right text-sm">
                    <thead>
                        <tr class="bg-primary text-white">
                            <th class="py-3 px-4 font-semibold">الكتاب</th>
                            <th class="py-3 px-4 font-semibold">الكاتب</th>
                            <th class="py-3 px-4 font-semibold text-center">المجموع</th>
                            <th class="py-3 px-4 font-semibold text-center">التاريخ</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                        @foreach (var sale in Model.RecentSales)
                        {
                            <tr class="row-hover bg-surface-light dark:bg-surface-dark">
                                <td class="py-3 px-4 font-medium text-slate-900 dark:text-slate-100">@sale.BookTitle</td>
                                <td class="py-3 px-4 text-slate-600 dark:text-slate-400">@sale.AuthorName</td>
                                <td class="py-3 px-4 text-center font-bold text-primary dark:text-secondary">@sale.TotalAmount.ToString("N2")</td>
                                <td class="py-3 px-4 text-center text-xs text-slate-500">@sale.SaleDate.ToString("yyyy-MM-dd")</td>
                            </tr>
                        }
                        @if (!Model.RecentSales.Any())
                        {
                            <tr><td colspan="4" class="text-center text-slate-400 py-6">لا توجد مبيعات</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Expiring Contracts Table -->
        <div class="bg-surface-light dark:bg-surface-dark rounded shadow-md border border-slate-200 dark:border-slate-700 overflow-hidden">
            <div class="p-6 border-b border-slate-200 dark:border-slate-700 flex justify-between items-center">
                <div class="flex items-center space-x-2 space-x-reverse">
                    <span class="material-icons-round text-yellow-500">warning</span>
                    <h3 class="text-lg font-bold text-slate-800 dark:text-white">عقود تنتهي قريباً</h3>
                </div>
                <a asp-area="Admin" asp-controller="Author" asp-action="Index"
                   class="text-sm text-primary dark:text-secondary font-semibold hover:underline">إدارة المؤلفين</a>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-right text-sm">
                    <thead>
                        <tr class="bg-yellow-500 text-white">
                            <th class="py-3 px-4 font-semibold">المؤلف</th>
                            <th class="py-3 px-4 font-semibold text-center">تاريخ الانتهاء</th>
                            <th class="py-3 px-4 font-semibold text-center">المتبقي</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
                        @foreach (var author in Model.ExpiringAuthors)
                        {
                            <tr class="row-hover bg-surface-light dark:bg-surface-dark">
                                <td class="py-3 px-4 font-bold text-slate-900 dark:text-slate-100">@author.Name</td>
                                <td class="py-3 px-4 text-center text-slate-600 dark:text-slate-400">@author.ContractEnd?.ToString("yyyy-MM-dd")</td>
                                <td class="py-3 px-4 text-center">
                                    @if (author.ContractEnd.HasValue)
                                    {
                                        <span class="countdown text-xs font-mono text-yellow-600 font-bold" data-deadline="@author.ContractEnd.Value.ToString("o")">
                                            جاري الحساب...
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!Model.ExpiringAuthors.Any())
                        {
                            <tr><td colspan="3" class="text-center text-slate-400 py-6">لا توجد عقود تنتهي قريباً</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

    </div>
</main>
