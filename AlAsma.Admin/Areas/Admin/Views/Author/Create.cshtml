@model AuthorCreateDto
@{
    ViewData["Title"] = "إضافة مؤلف جديد";
}

    <main class="flex-grow container mx-auto px-4 sm:px-6 py-8">
        <div class="max-w-2xl mx-auto">
            <div class="bg-white dark:bg-slate-800 rounded shadow-md p-8 border border-slate-200 dark:border-slate-700">
                <div class="flex items-center mb-6 border-b border-slate-100 dark:border-slate-700 pb-4">
                    <span class="material-icons-round text-primary ml-2">person_add</span>
                    <h2 class="text-xl font-bold text-slate-800 dark:text-white">إضافة مؤلف جديد</h2>
                </div>
                <form asp-action="Create" method="post" class="space-y-5">
                    <div asp-validation-summary="ModelOnly" class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded text-sm"></div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                        <div>
                            <label asp-for="Name" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">الاسم</label>
                            <input asp-for="Name" class="w-full rounded border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-white focus:border-primary focus:ring-primary text-sm" placeholder="اسم المؤلف" />
                            <span asp-validation-for="Name" class="text-red-500 text-xs mt-1 block"></span>
                        </div>
                        <div>
                            <label asp-for="Code" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">الكود</label>
                            <input asp-for="Code" class="w-full rounded border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-white focus:border-primary focus:ring-primary text-sm" placeholder="كود فريد" />
                            <span asp-validation-for="Code" class="text-red-500 text-xs mt-1 block"></span>
                        </div>
                        <div class="md:col-span-2">
                            <label asp-for="Password" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">كلمة المرور</label>
                            <input asp-for="Password" type="password" class="w-full rounded border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-white focus:border-primary focus:ring-primary text-sm" placeholder="كلمة مرور قوية" />
                            <span asp-validation-for="Password" class="text-red-500 text-xs mt-1 block"></span>
                        </div>
                        <div>
                            <label asp-for="ContractStart" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">تاريخ بداية العقد</label>
                            <input asp-for="ContractStart" type="date" class="w-full rounded border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-white focus:border-primary focus:ring-primary text-sm" />
                            <span asp-validation-for="ContractStart" class="text-red-500 text-xs mt-1 block"></span>
                        </div>
                        <div>
                            <label asp-for="ContractEnd" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">تاريخ انتهاء العقد</label>
                            <input asp-for="ContractEnd" type="date" class="w-full rounded border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-white focus:border-primary focus:ring-primary text-sm" />
                            <span asp-validation-for="ContractEnd" class="text-red-500 text-xs mt-1 block"></span>
                        </div>
                        <div class="md:col-span-2">
                            <label asp-for="BasicFees" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">المصروفات الأساسية <span class="text-slate-400 text-xs">(ج.م)</span></label>
                            <input asp-for="BasicFees" type="number" step="0.01" min="0" class="w-full rounded border-slate-300 dark:border-slate-600 dark:bg-slate-700 dark:text-white focus:border-primary focus:ring-primary text-sm" placeholder="0.00" />
                            <span asp-validation-for="BasicFees" class="text-red-500 text-xs mt-1 block"></span>
                        </div>
                    </div>

                    <div class="flex justify-end gap-3 pt-4 border-t border-slate-100 dark:border-slate-700 mt-6">
                        <a asp-action="Index" class="px-5 py-2 rounded border border-slate-300 dark:border-slate-600 text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700 text-sm font-medium transition-colors">إلغاء</a>
                        <button type="submit" class="bg-primary hover:bg-primary/90 text-white px-6 py-2 rounded font-medium text-sm flex items-center gap-2 transition-colors">
                            <span class="material-icons-round text-sm">save</span>
                            حفظ
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </main>

    @section Scripts {
        @{
            await Html.RenderPartialAsync("_ValidationScriptsPartial");
        }
}

