@model SaleListDto
@{
    ViewData["Title"] = "تأكيد حذف العملية";
}

<div class="flex items-center justify-center min-h-[60vh]">
  <div class="w-full max-w-md">
    <div class="bg-white rounded-xl shadow-lg border border-slate-200 overflow-hidden">

      @* Header *@
      <div class="bg-red-50 border-b border-red-100 px-6 py-5 flex items-center gap-3">
        <div class="bg-red-100 rounded-full p-2">
          <span class="material-icons-round text-accent text-2xl">warning_amber</span>
        </div>
        <div>
          <h2 class="text-lg font-bold text-slate-800">تأكيد الحذف</h2>
          <p class="text-xs text-slate-500 mt-0.5">هذا الإجراء لا يمكن التراجع عنه</p>
        </div>
      </div>

      @* Body *@
      <div class="px-6 py-6 space-y-3">
        <div class="flex justify-between items-center py-2 border-b border-slate-100">
          <span class="text-sm text-slate-500">اسم الكتاب</span>
          <span class="text-sm font-semibold text-slate-900">@Model.BookTitle</span>
        </div>
        <div class="flex justify-between items-center py-2 border-b border-slate-100">
          <span class="text-sm text-slate-500">المؤلف</span>
          <span class="text-sm font-medium text-slate-700">@Model.AuthorName</span>
        </div>
        <div class="flex justify-between items-center py-2 border-b border-slate-100">
          <span class="text-sm text-slate-500">القيمة الإجمالية</span>
          <span class="text-sm font-bold text-slate-900">@Model.TotalAmount.ToString("N2") ج.م</span>
        </div>
        <div class="flex justify-between items-center py-2 border-b border-slate-100">
          <span class="text-sm text-slate-500">المنفذ</span>
          <span class="text-sm text-slate-700">@Model.StoreLocation</span>
        </div>
        <div class="flex justify-between items-center py-2">
          <span class="text-sm text-slate-500">تاريخ العملية</span>
          <span class="text-sm text-slate-700" dir="ltr">@Model.SaleDate.ToString("yyyy-MM-dd HH:mm")</span>
        </div>
      </div>

      @* Footer *@
      <div class="px-4 sm:px-6 py-4 border-t border-slate-100 bg-slate-50 flex flex-col-reverse sm:flex-row justify-end gap-2 sm:gap-3">
        <a asp-action="Index"
           class="w-full sm:w-auto text-center px-5 py-3 rounded-lg border border-slate-300 text-slate-600 hover:bg-slate-100 text-sm font-medium transition-colors">
          إلغاء
        </a>
        <form asp-action="Delete" method="post" class="w-full sm:w-auto">
          @Html.AntiForgeryToken()
          <input type="hidden" asp-for="Id" />
          <button type="submit"
                  class="w-full sm:w-auto bg-accent hover:bg-red-700 text-white px-5 py-3 rounded-lg font-medium text-sm flex items-center justify-center gap-2 transition-colors">
            <span class="material-icons-round text-sm block">delete</span>
            حذف نهائي
          </button>
        </form>
      </div>

    </div>
  </div>
</div>
