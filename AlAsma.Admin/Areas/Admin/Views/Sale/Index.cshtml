    </form>
  </div>
</div>

<!-- Bulk Edit Modal -->
<div id="bulkEditModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center backdrop-blur-sm">
  <div class="bg-white dark:bg-slate-800 rounded-xl shadow-xl w-full max-w-md mx-4 overflow-hidden border border-slate-200 dark:border-slate-700">
    <div class="bg-amber-50 dark:bg-amber-900/20 px-6 py-4 border-b border-amber-100 dark:border-amber-800/30 flex items-center justify-between">
      <div class="flex items-center gap-2">
         <span class="material-icons-round text-amber-500">edit_note</span>
         <h3 class="text-sm font-bold text-amber-700 dark:text-amber-400">تعديل المصروفات</h3>
      </div>
      <button onclick="closeBulkEditModal()" class="text-amber-400 hover:text-amber-600"><span class="material-icons-round text-sm">close</span></button>
    </div>
    <form id="bulkExpensesForm" asp-action="BulkEditExpenses" method="post" class="p-6">
      @Html.AntiForgeryToken()
      <input type="hidden" name="q" value="@sq" />
      <input type="hidden" name="field" value="@sf" />

      <p class="text-xs text-slate-500 dark:text-slate-400 mb-4 bg-slate-50 dark:bg-slate-800/50 p-3 rounded-lg border border-slate-100 dark:border-slate-700">
        سيتم تعديل <span class="font-bold text-slate-800 dark:text-slate-200">@ViewBag.TotalCount</span> سجل يطابق الفرز الحالي.
      </p>

      <div class="mb-5">
        <label class="block text-xs font-medium text-slate-700 dark:text-slate-300 mb-1.5">المصروفات الجديدة (للنسخة)</label>
        <input type="number" name="newBasicExpenses" step="0.01" min="0" required
               class="w-full text-sm rounded-lg border-slate-300 focus:border-amber-500 focus:ring-amber-500 dark:bg-slate-900 dark:border-slate-700 dark:text-white" />
      </div>

      <div class="flex justify-end gap-2 pt-2">
         <button type="button" onclick="closeBulkEditModal()" class="px-4 py-2 rounded-lg text-xs font-medium text-slate-600 bg-slate-100 hover:bg-slate-200 dark:text-slate-300 dark:bg-slate-700 dark:hover:bg-slate-600">إلغاء</button>
         <button type="submit" class="px-4 py-2 rounded-lg text-xs font-medium text-white bg-amber-500 hover:bg-amber-600 flex items-center gap-1">
           <span class="material-icons-round text-[14px]">save</span> تطبيق التعديل
         </button>
      </div>
    </form>
  </div>
</div>

</main>

@section Scripts {
<script>
// Live total calc (UI only — server recalculates)
function calcTotal() {
    const p = parseFloat(document.getElementById('salePrice')?.value) || 0;
    const q = parseInt(document.getElementById('qty')?.value) || 0;
    const e = parseFloat(document.getElementById('expenses')?.value) || 0;
    const t = Math.max(0, (p * q) - (e * q));
    document.getElementById('totalDisplay').innerHTML = t.toFixed(2) + ' <span class="text-sm font-normal text-slate-500">ج.م</span>';
}

// Bulk Edit Modal — sends current filter (q+field), no saleIds needed
function openBulkEditModal() {
    document.getElementById('bulkEditModal').classList.remove('hidden');
}
function closeBulkEditModal() { document.getElementById('bulkEditModal').classList.add('hidden'); }
document.getElementById('bulkEditModal').addEventListener('click', function(e) {
    if(e.target === this) closeBulkEditModal();
});

// Edit modal
function editFromRow(btn) {
    document.getElementById('editId').value = btn.dataset.id;
    document.getElementById('editBookTitle').value = btn.dataset.booktitle;
    document.getElementById('editAuthorId').value = btn.dataset.authorid;
    document.getElementById('editStoreLocation').value = btn.dataset.storelocation;
    document.getElementById('editSalePrice').value = btn.dataset.saleprice;
    document.getElementById('editQuantity').value = btn.dataset.quantity;
    document.getElementById('editExpenses').value = btn.dataset.expenses;
    document.getElementById('editModal').classList.remove('hidden');
}
function closeEditModal() {
    document.getElementById('editModal').classList.add('hidden');
}
document.getElementById('editModal').addEventListener('click', function(e) {
    if(e.target === this) closeEditModal();
});

// ─── Server-side Live Search ───
(function() {
    const searchInput = document.getElementById('searchInput');
    const searchForm = document.getElementById('searchForm');
    if (!searchInput || !searchForm) return;

    // Focus input and set cursor to end on load if search is active
    if (searchInput.value.length > 0) {
        searchInput.focus();
        const val = searchInput.value;
        searchInput.value = '';
        searchInput.value = val;
    }

    let debounceTimer;
    let lastQuery = searchInput.value.trim();

    searchInput.addEventListener('input', function() {
        clearTimeout(debounceTimer);
        debounceTimer = setTimeout(() => {
            const currentQuery = searchInput.value.trim();
            if (currentQuery !== lastQuery) {
                if (currentQuery.length >= 2 || currentQuery.length === 0) {
                    // Reset to page 1 on new search
                    const pageInput = searchForm.querySelector('input[name="page"]');
                    if(pageInput) pageInput.value = "1";
                    
                    searchForm.submit();
                }
            }
        }, 400); // 400ms debounce
    });
})();
</script>
}
