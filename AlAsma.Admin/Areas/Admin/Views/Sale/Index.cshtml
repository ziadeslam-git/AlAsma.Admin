@model IEnumerable<SaleListDto>
@{
    ViewData["Title"] = "المبيعات";
    var authors = ViewBag.Authors as IEnumerable<SelectListItem> ?? Enumerable.Empty<SelectListItem>();
}

<main class="flex-grow container mx-auto px-4 sm:px-6 py-8">

<div class="flex flex-col md:flex-row justify-between items-start md:items-center mb-8">
  <div>
    <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-2">لوحة المبيعات</h2>
    <p class="text-slate-500 dark:text-slate-400"></p>
  </div>
  <div class="mt-4 md:mt-0 flex items-center gap-2 bg-white dark:bg-slate-800 px-4 py-2 rounded-lg shadow-sm border border-slate-200 dark:border-slate-700">
    <span class="material-icons-round text-slate-400 text-lg">calendar_today</span>
    <span class="text-sm font-medium text-slate-700 dark:text-slate-300">@DateTime.Now.ToString("dd/MM/yyyy")</span>
  </div>
</div>



@* Stats Cards *@
<div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-6 mb-6 sm:mb-10">
  <div class="bg-white dark:bg-slate-800 rounded-xl shadow-sm p-4 sm:p-6 border border-slate-100 dark:border-slate-700">
    <div class="flex justify-between items-start mb-4">
      <div class="bg-blue-50 dark:bg-blue-900/30 p-3 rounded-xl text-blue-500">
        <span class="material-icons-round">receipt_long</span>
      </div>
      <span class="flex items-center text-xs font-semibold text-green-600 bg-green-50 dark:bg-green-900/20 px-2 py-1 rounded-lg">
        <span class="material-icons-round text-sm ml-1">trending_up</span> مبيعات
      </span>
    </div>
    <h3 class="text-slate-500 dark:text-slate-400 text-sm font-medium mb-1">إجمالي العمليات</h3>
    <p class="text-xl sm:text-3xl font-bold text-slate-900 dark:text-white">@ViewBag.TotalCount</p>
  </div>
  <div class="bg-white dark:bg-slate-800 rounded-xl shadow-sm p-4 sm:p-6 border border-slate-100 dark:border-slate-700">
    <div class="flex justify-between items-start mb-4">
      <div class="bg-green-50 dark:bg-green-900/30 p-3 rounded-xl text-green-500">
        <span class="material-icons-round">payments</span>
      </div>
      <span class="flex items-center text-xs font-semibold text-green-600 bg-green-50 dark:bg-green-900/20 px-2 py-1 rounded-lg">
        <span class="material-icons-round text-sm ml-1">trending_up</span> إيرادات
      </span>
    </div>
    <h3 class="text-slate-500 dark:text-slate-400 text-sm font-medium mb-1">إجمالي المبالغ</h3>
    <p class="text-xl sm:text-3xl font-bold text-slate-900 dark:text-white flex items-baseline">
      @(((decimal)ViewBag.TotalRevenue).ToString("N2"))
      <span class="text-sm font-normal text-slate-500 mr-1">ج.م</span>
    </p>
  </div>
  <div class="bg-white dark:bg-slate-800 rounded-xl shadow-sm p-4 sm:p-6 border border-slate-100 dark:border-slate-700">
    <div class="flex justify-between items-start mb-4">
      <div class="bg-purple-50 dark:bg-purple-900/30 p-3 rounded-xl text-purple-500">
        <span class="material-icons-round">menu_book</span>
      </div>
      <span class="text-xs font-semibold text-slate-500 bg-slate-50 dark:bg-slate-700 px-2 py-1 rounded-lg">إجمالي</span>
    </div>
    <h3 class="text-slate-500 dark:text-slate-400 text-sm font-medium mb-1">كتب مباعة</h3>
    <p class="text-xl sm:text-3xl font-bold text-slate-900 dark:text-white">@ViewBag.TotalQuantity</p>
  </div>
  <div class="bg-white dark:bg-slate-800 rounded-xl shadow-sm p-4 sm:p-6 border border-slate-100 dark:border-slate-700">
    <div class="flex justify-between items-start mb-4">
      <div class="bg-red-50 dark:bg-red-900/30 p-3 rounded-xl text-red-500">
        <span class="material-icons-round">money_off</span>
      </div>
      <span class="flex items-center text-xs font-semibold text-red-600 bg-red-50 dark:bg-red-900/20 px-2 py-1 rounded-lg">مصروفات</span>
    </div>
    <h3 class="text-slate-500 dark:text-slate-400 text-sm font-medium mb-1">إجمالي المصروفات</h3>
    <p class="text-xl sm:text-3xl font-bold text-slate-900 dark:text-white flex items-baseline">
      @(((decimal)ViewBag.TotalExpenses).ToString("N2"))
      <span class="text-sm font-normal text-slate-500 mr-1">ج.م</span>
    </p>
  </div>
</div>

@* Add Sale Form *@
<div class="bg-white dark:bg-slate-800 rounded-xl shadow-md p-6 lg:p-8 mb-10 border border-slate-200 dark:border-slate-700">
  <div class="flex items-center mb-6 border-b border-slate-100 dark:border-slate-700 pb-4">
    <span class="material-icons-round text-primary ml-2">add_card</span>
    <h3 class="text-lg font-bold text-slate-800 dark:text-white">تسجيل عملية جديدة</h3>
  </div>
  <form asp-action="Create" method="post" class="space-y-6">
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="bg-red-50 border border-red-200 text-red-700 px-4 py-3 rounded-lg text-sm"></div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
      <div>
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">اسم الكتاب</label>
        <input name="BookTitle" class="w-full rounded-lg border-slate-300 focus:border-primary focus:ring-primary text-sm dark:bg-slate-700 dark:border-slate-600 dark:text-white" placeholder="أدخل اسم الكتاب" type="text" required />
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">الكاتب</label>
        <select name="AuthorId" class="w-full rounded-lg border-slate-300 focus:border-primary focus:ring-primary text-sm dark:bg-slate-700 dark:border-slate-600 dark:text-white">
          <option value="">-- اختر مؤلف --</option>
          @foreach (var a in authors)
          {
            <option value="@a.Value">@a.Text</option>
          }
        </select>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">منفذ البيع</label>
        <input name="StoreLocation" class="w-full rounded-lg border-slate-300 focus:border-primary focus:ring-primary text-sm dark:bg-slate-700 dark:border-slate-600 dark:text-white" placeholder="مثال: المكتب الرئيسي" type="text" required />
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">سعر البيع</label>
        <div class="relative">
          <input name="SalePrice" id="salePrice" class="w-full rounded-lg border-slate-300 focus:border-primary focus:ring-primary text-sm pl-12 dark:bg-slate-700 dark:border-slate-600 dark:text-white" placeholder="0.00" type="number" step="0.01" min="0.01" required oninput="calcTotal()" />
          <span class="absolute left-3 top-2.5 text-slate-400 text-sm">ج.م</span>
        </div>
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">الكمية</label>
        <input name="Quantity" id="qty" class="w-full rounded-lg border-slate-300 focus:border-primary focus:ring-primary text-sm dark:bg-slate-700 dark:border-slate-600 dark:text-white" min="1" type="number" value="1" required oninput="calcTotal()" />
      </div>
      <div>
        <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-2">مصروفات إضافية (للنسخة)</label>
        <div class="relative">
          <input name="BasicExpenses" id="expenses" class="w-full rounded-lg border-slate-300 focus:border-primary focus:ring-primary text-sm pl-12 dark:bg-slate-700 dark:border-slate-600 dark:text-white" placeholder="0.00" type="number" step="0.01" min="0" value="0" oninput="calcTotal()" />
          <span class="absolute left-3 top-2.5 text-slate-400 text-sm">ج.م</span>
        </div>
      </div>
    </div>
    <div class="flex flex-col sm:flex-row justify-between items-center pt-6 border-t border-slate-100 dark:border-slate-700">
      <button type="submit" class="bg-primary hover:bg-primary/90 text-white font-medium py-2.5 px-6 rounded-lg flex items-center gap-2 transition-colors w-full sm:w-auto mb-4 sm:mb-0">
        <span class="material-icons-round text-sm">save</span> حفظ العملية
      </button>
      <div class="bg-slate-50 dark:bg-slate-700 px-6 py-3 rounded-xl border border-slate-200 dark:border-slate-600 flex items-center gap-3">
        <span class="text-slate-500 dark:text-slate-400 font-medium text-sm">المجموع النهائي:</span>
        <span id="totalDisplay" class="text-xl font-bold text-slate-900 dark:text-white">0.00 <span class="text-sm font-normal text-slate-500">ج.م</span></span>
      </div>
    </div>
  </form>
</div>

@* Sales Table *@
<div class="bg-white dark:bg-slate-800 rounded-xl shadow-md border border-slate-200 dark:border-slate-700 overflow-hidden">
  <div class="p-5 border-b border-slate-200 dark:border-slate-700 flex flex-col sm:flex-row justify-between items-center gap-4">
    <div class="flex items-center gap-2">
      <span class="material-icons-round text-slate-500">history</span>
                <h3 class="text-lg font-bold text-slate-800 dark:text-white">سجل المبيعات </h3>
    </div>
    @{
        string sq = ViewBag.SearchQuery ?? "";
        string sf = ViewBag.SearchField ?? "book";
    }
    <div class="flex flex-col gap-2 flex-grow max-w-2xl">
      <form id="searchForm" method="get" asp-action="Index" class="flex items-center gap-2">
        <input type="hidden" name="page" value="1" />
        <input type="hidden" name="field" value="@sf" />
        <div class="relative flex-grow">
          <span class="absolute right-3 top-2.5 text-slate-400 material-icons-round text-sm">search</span>
          <input id="searchInput"
                 name="q"
                 value="@sq"
                 class="w-full bg-slate-100 dark:bg-slate-700 border border-slate-200 dark:border-slate-600 rounded-full py-2 pr-9 pl-4 text-sm placeholder-slate-400 dark:text-white focus:ring-2 focus:ring-primary focus:outline-none"
                 placeholder="بحث..." />
        </div>
        <button type="submit"
                class="bg-primary hover:bg-primary/90 text-white px-4 py-2 rounded-full text-sm font-medium flex items-center gap-1 whitespace-nowrap">
          <span class="material-icons-round text-sm">search</span>
          <span class="hidden sm:inline">بحث</span>
        </button>
      </form>
      @* Filter type buttons — below the search bar *@
      <div class="flex flex-wrap gap-1.5">
        @{
            var fields = new[]
            {
                ("book",   "اسم الكتاب"),
                ("author", "اسم الكاتب"),
                ("code",   "كود الكاتب"),
                ("store",  "المنفذ")
            };
        }
        @foreach (var (fval, flabel) in fields)
        {
            var isActive = sf == fval;
            <a asp-action="Index"
               asp-route-q="@sq"
               asp-route-field="@fval"
               asp-route-page="1"
               class="@(isActive ? "bg-primary text-white shadow-sm" : "bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 hover:bg-slate-200 dark:hover:bg-slate-600")
                      px-3 py-1.5 rounded-full text-xs font-medium transition-colors whitespace-nowrap">
                @flabel
            </a>
        }
        @if (!string.IsNullOrWhiteSpace(sq))
        {
            <a asp-action="Index" asp-route-page="1"
               class="flex items-center gap-0.5 bg-red-50 dark:bg-red-900/30 text-red-500 px-2.5 py-1.5 rounded-full text-xs font-medium hover:bg-red-100 transition-colors">
                <span class="material-icons-round text-xs">close</span> مسح
            </a>
        }
      </div>
    </div>
    <div class="flex items-center gap-2">
      <button type="button" onclick="openBulkEditModal()"
        class="flex items-center gap-1 bg-amber-500 hover:bg-amber-600 text-white px-4 py-2 rounded-lg text-sm font-medium whitespace-nowrap transition-colors shadow-sm">
        <span class="material-icons-round text-sm">edit_note</span>
        <span class="hidden sm:inline">تعديل المصروفات</span>
      </button>
      <a asp-action="Export" class="flex items-center gap-1 border border-slate-300 dark:border-slate-600 hover:bg-slate-50 dark:hover:bg-slate-700 text-slate-700 dark:text-slate-300 px-4 py-2 rounded-lg text-sm font-medium whitespace-nowrap transition-colors shadow-sm">
        <span class="material-icons-round text-sm">download</span> تصدير
      </a>
    </div>
  </div>
  <div class="md:hidden divide-y divide-slate-100 dark:divide-slate-700" id="salesMobileList">
    @foreach (var sale in Model)
    {
      <div class="p-4 hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors group">
        <div class="flex items-center justify-between mb-3">
          <div class="flex items-center gap-2">
            <div class="w-9 h-9 rounded-lg bg-orange-50 dark:bg-orange-900/30 text-orange-600 dark:text-orange-300 flex items-center justify-center">
              <span class="material-icons-round text-[17px] leading-none">auto_stories</span>
            </div>
            <div>
              <p class="font-semibold text-slate-900 dark:text-white text-sm">@sale.BookTitle</p>
              <p class="text-xs text-slate-500 dark:text-slate-400">@sale.AuthorName</p>
            </div>
          </div>
          <div class="flex items-center gap-2">
            <button onclick="editFromRow(this)"
                    data-id="@sale.Id"
                    data-booktitle="@sale.BookTitle"
                    data-authorid="@sale.AuthorId"
                    data-storelocation="@sale.StoreLocation"
                    data-saleprice="@sale.SalePrice"
                    data-quantity="@sale.Quantity"
                    data-expenses="@sale.BasicExpenses"
                    class="bg-blue-50 dark:bg-blue-900/30 text-blue-500 p-2 rounded-lg">
              <span class="material-icons-round text-sm block">edit</span>
            </button>
            <a asp-action="Delete" asp-route-id="@sale.Id"
               class="bg-red-50 dark:bg-red-900/30 text-red-500 p-2 rounded-lg">
              <span class="material-icons-round text-sm block">delete</span>
            </a>
          </div>
        </div>
        <div class="grid grid-cols-3 gap-2 text-xs">
          <div class="bg-slate-50 dark:bg-slate-700 rounded-lg p-2 text-center">
            <p class="text-slate-400 mb-0.5">السعر</p>
            <p class="font-semibold text-slate-700 dark:text-slate-300">@sale.SalePrice.ToString("N0")</p>
          </div>
          <div class="bg-slate-50 dark:bg-slate-700 rounded-lg p-2 text-center">
            <p class="text-slate-400 mb-0.5">الكمية</p>
            <p class="font-semibold text-slate-700 dark:text-slate-300">@sale.Quantity</p>
          </div>
          <div class="bg-red-50 dark:bg-red-900/30 rounded-lg p-2 text-center">
            <p class="text-red-600 dark:text-red-400 mb-0.5">المجموع</p>
            <p class="font-bold text-red-700 dark:text-red-300">@(Math.Max(0, (sale.SalePrice * sale.Quantity) - (sale.BasicExpenses * sale.Quantity)).ToString("N0"))</p>
          </div>
        </div>
        <div class="flex items-center justify-between mt-2 text-xs text-slate-400">
          <span>@sale.StoreLocation</span>
          <span dir="ltr">@sale.SaleDate.ToString("dd/MM/yyyy")</span>
        </div>
      </div>
    }
    @if (!Model.Any())
    {
      <div class="py-12 text-center text-slate-400">
        <span class="material-icons-round text-4xl block mb-2">inbox</span>
        <p class="text-sm">لا توجد عمليات بعد</p>
      </div>
    }
  </div>
  <div class="hidden md:block overflow-x-auto">
    <table class="w-full text-right border-collapse text-sm" id="salesTable">
      <thead>
        <tr class="bg-primary text-white">
          <th class="py-4 px-6 font-semibold">اسم الكتاب</th>
          <th class="py-4 px-4 font-semibold">الكاتب</th>
          <th class="py-4 px-4 font-semibold">كود الكاتب</th>
          <th class="py-4 px-4 font-semibold text-center">السعر</th>
          <th class="py-4 px-4 font-semibold text-center">المصروفات</th>
          <th class="py-4 px-4 font-semibold text-center">المجموع</th>
          <th class="py-4 px-4 font-semibold text-center">الكمية</th>
          <th class="py-4 px-4 font-semibold text-center">المنفذ</th>
          <th class="py-4 px-4 font-semibold text-center">التاريخ والوقت</th>
          <th class="py-4 px-6 font-semibold text-center">إجراءات</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100 dark:divide-slate-700" id="salesTableBody">
        @foreach (var sale in Model)
        {
          <tr class="hover:bg-emerald-50/50 dark:hover:bg-emerald-900/10 transition-colors group">
            <td class="py-4 px-6">
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-orange-50 dark:bg-orange-900/30 text-orange-600 dark:text-orange-300 flex items-center justify-center">
                  <span class="material-icons-round text-[15px] leading-none">auto_stories</span>
                </div>
                <span class="font-medium text-slate-900 dark:text-white">@sale.BookTitle</span>
              </div>
            </td>
            <td class="py-4 px-4 text-slate-600 dark:text-slate-300">@sale.AuthorName</td>
            <td class="py-4 px-4"><span class="bg-slate-100 dark:bg-slate-700 text-slate-600 dark:text-slate-300 px-2 py-1 rounded-lg text-xs font-mono">@sale.AuthorCode</span></td>
            <td class="py-4 px-4 text-center font-medium dark:text-slate-200">@sale.SalePrice.ToString("N2")</td>
            <td class="py-4 px-4 text-center text-slate-500 dark:text-slate-400">@sale.BasicExpenses.ToString("N2")</td>
            <td class="py-4 px-4 text-center font-bold text-red-600 dark:text-red-400">@(Math.Max(0, (sale.SalePrice * sale.Quantity) - (sale.BasicExpenses * sale.Quantity)).ToString("N2"))</td>
            <td class="py-4 px-4 text-center dark:text-slate-200">@sale.Quantity</td>
            <td class="py-4 px-4 text-center text-slate-600 dark:text-slate-300">@sale.StoreLocation</td>
            <td class="py-4 px-4 text-center text-xs text-slate-500 dark:text-slate-400" dir="ltr">@sale.SaleDate.ToString("dd/MM/yyyy")<br/>@sale.SaleDate.ToString("hh:mm tt")</td>
            <td class="py-4 px-6 text-center">
              <div class="flex items-center justify-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                <button onclick="editFromRow(this)"
                        data-id="@sale.Id"
                        data-booktitle="@sale.BookTitle"
                        data-authorid="@sale.AuthorId"
                        data-storelocation="@sale.StoreLocation"
                        data-saleprice="@sale.SalePrice"
                        data-quantity="@sale.Quantity"
                        data-expenses="@sale.BasicExpenses"
                        class="text-blue-500 hover:text-blue-700 bg-blue-50 dark:bg-blue-900/30 p-1.5 rounded-lg" title="تعديل">
                  <span class="material-icons-round text-sm">edit</span>
                </button>
                <a asp-action="Delete" asp-route-id="@sale.Id"
                   class="text-accent hover:text-red-700 bg-red-50 dark:bg-red-900/30 p-1.5 rounded-lg" title="حذف">
                  <span class="material-icons-round text-sm">delete</span>
                </a>
              </div>
            </td>
          </tr>
        }
        @if (!Model.Any())
        {
          <tr><td colspan="10" class="py-12 text-center text-slate-400">
            <span class="material-icons-round text-4xl block mb-2">inbox</span>
            لا توجد عمليات بيع بعد
          </td></tr>
        }
      </tbody>
    </table>
  </div>
  
  @{
      int currentPage = ViewBag.CurrentPage;
      int totalPages = ViewBag.TotalPages;
      int totalCount = ViewBag.TotalCount;
      string psq = ViewBag.SearchQuery ?? "";
      string psf = ViewBag.SearchField ?? "book";
  }

  <div class="px-6 py-4 border-t border-slate-200 flex items-center justify-between bg-slate-50 flex-wrap gap-3">
    <span class="text-sm text-slate-500">
      عرض @((currentPage - 1) * 10 + 1) إلى @(Math.Min(currentPage * 10, totalCount)) من @totalCount سجل
    </span>
    <div class="flex items-center gap-1">

      @* Previous *@
      @if (currentPage > 1)
      {
        <a asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-q="@psq" asp-route-field="@psf"
           class="w-9 h-9 flex items-center justify-center rounded-lg border border-slate-300 text-slate-600 hover:bg-slate-100 transition-colors">
          <span class="material-icons-round text-sm">chevron_right</span>
        </a>
      }
      else
      {
        <span class="w-9 h-9 flex items-center justify-center rounded-lg border border-slate-200 text-slate-300 cursor-not-allowed">
          <span class="material-icons-round text-sm">chevron_right</span>
        </span>
      }

      @* Page numbers — show max 5 around current *@
      @{
        int startPage = Math.Max(1, currentPage - 2);
        int endPage = Math.Min(totalPages, currentPage + 2);
      }

      @if (startPage > 1)
      {
        <a asp-action="Index" asp-route-page="1" asp-route-q="@psq" asp-route-field="@psf"
           class="w-9 h-9 sm:w-auto sm:h-auto sm:px-3 sm:py-1.5 flex items-center justify-center rounded-lg border border-slate-300 text-slate-600 hover:bg-slate-100 text-sm font-medium transition-colors">1</a>
        @if (startPage > 2)
        {
          <span class="px-2 text-slate-400 text-sm">...</span>
        }
      }

      @for (int i = startPage; i <= endPage; i++)
      {
        @if (i == currentPage)
        {
          <span class="w-9 h-9 sm:w-auto sm:h-auto sm:px-3 sm:py-1.5 flex items-center justify-center rounded-lg bg-primary text-white text-sm font-medium">@i</span>
        }
        else
        {
          <a asp-action="Index" asp-route-page="@i" asp-route-q="@psq" asp-route-field="@psf"
             class="w-9 h-9 sm:w-auto sm:h-auto sm:px-3 sm:py-1.5 flex items-center justify-center rounded-lg border border-slate-300 text-slate-600 hover:bg-slate-100 text-sm font-medium transition-colors">@i</a>
        }
      }

      @if (endPage < totalPages)
      {
        @if (endPage < totalPages - 1)
        {
          <span class="px-2 text-slate-400 text-sm">...</span>
        }
        <a asp-action="Index" asp-route-page="@totalPages" asp-route-q="@psq" asp-route-field="@psf"
           class="w-9 h-9 sm:w-auto sm:h-auto sm:px-3 sm:py-1.5 flex items-center justify-center rounded-lg border border-slate-300 text-slate-600 hover:bg-slate-100 text-sm font-medium transition-colors">@totalPages</a>
      }

      @* Next *@
      @if (currentPage < totalPages)
      {
        <a asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-q="@psq" asp-route-field="@psf"
           class="w-9 h-9 flex items-center justify-center rounded-lg border border-slate-300 text-slate-600 hover:bg-slate-100 transition-colors">
          <span class="material-icons-round text-sm">chevron_left</span>
        </a>
      }
      else
      {
        <span class="w-9 h-9 flex items-center justify-center rounded-lg border border-slate-200 text-slate-300 cursor-not-allowed">
          <span class="material-icons-round text-sm">chevron_left</span>
        </span>
      }

    </div>
  </div>
</div>

@* Hidden edit form (inline edit modal) *@
<div id="editModal" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center">
  <div class="bg-white dark:bg-slate-800 rounded-xl shadow-xl p-8 w-full max-w-2xl mx-4">
    <div class="flex items-center justify-between mb-6 border-b border-slate-100 dark:border-slate-700 pb-4">
      <div class="flex items-center gap-2">
        <span class="material-icons-round text-primary">edit</span>
        <h3 class="text-lg font-bold text-slate-800 dark:text-white">تعديل عملية البيع</h3>
      </div>
      <button onclick="closeEditModal()" class="text-slate-400 hover:text-slate-600"><span class="material-icons-round">close</span></button>
    </div>
    <form asp-action="Edit" method="post" class="space-y-5">
      @Html.AntiForgeryToken()
      <input type="hidden" id="editId" name="Id" />
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">اسم الكتاب</label>
          <input id="editBookTitle" name="BookTitle" class="w-full rounded-lg border-slate-300 focus:border-primary focus:ring-primary text-sm dark:bg-slate-700 dark:border-slate-600 dark:text-white" type="text" required />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">الكاتب</label>
          <select id="editAuthorId" name="AuthorId" class="w-full rounded-lg border-slate-300 focus:border-primary focus:ring-primary text-sm dark:bg-slate-700 dark:border-slate-600 dark:text-white">
            @foreach (var a in authors)
            {
              <option value="@a.Value">@a.Text</option>
            }
          </select>
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">منفذ البيع</label>
          <input id="editStoreLocation" name="StoreLocation" class="w-full rounded-lg border-slate-300 focus:border-primary focus:ring-primary text-sm dark:bg-slate-700 dark:border-slate-600 dark:text-white" type="text" required />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">سعر البيع (ج.م)</label>
          <input id="editSalePrice" name="SalePrice" class="w-full rounded-lg border-slate-300 focus:border-primary focus:ring-primary text-sm dark:bg-slate-700 dark:border-slate-600 dark:text-white" type="number" step="0.01" min="0.01" required />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">الكمية</label>
          <input id="editQuantity" name="Quantity" class="w-full rounded-lg border-slate-300 focus:border-primary focus:ring-primary text-sm dark:bg-slate-700 dark:border-slate-600 dark:text-white" type="number" min="1" required />
        </div>
        <div>
          <label class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">مصروفات إضافية للنسخة (ج.م)</label>
          <input id="editExpenses" name="BasicExpenses" class="w-full rounded-lg border-slate-300 focus:border-primary focus:ring-primary text-sm dark:bg-slate-700 dark:border-slate-600 dark:text-white" type="number" step="0.01" min="0" />
        </div>
      </div>
      <div class="flex justify-end gap-3 pt-4 border-t border-slate-100 dark:border-slate-700">
        <button type="button" onclick="closeEditModal()" class="px-5 py-2 rounded-lg border border-slate-300 dark:border-slate-600 text-slate-600 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-700 text-sm font-medium">إلغاء</button>
        <button type="submit" class="bg-primary hover:bg-primary/90 text-white px-6 py-2 rounded-lg font-medium text-sm flex items-center gap-2">
          <span class="material-icons-round text-sm">save</span> حفظ التعديلات
        </button>
